      "content_script": "src/extension/content.tsx",
      "side_panel": "src/extension/sidepanel.tsx"
    },
    "tracked_dom_attributes": [
      "data-page",
      "data-verse-key",
      "data-chapter-id",
      "data-hizb"
    ],
    "reader_route_kinds": [
      "surah",
      "verse",
      "page",
      "juz",
      "hizb",
      "rub",
      "unknown"
    ],
    "session_tracking_rules": [
      "Session start is explicit.",
      "Each distinct observed page counts once per session.",
      "Repeated visibility does not increment progress.",
      "Backward scroll does not decrement progress.",
      "Forward jumps count only observed pages.",
      "Manual controls remain available for correction and fallback."
    ],
    "load_unpacked_steps": [
      "Run npm run build or npm run build:extension.",
      "Load dist/extension in chrome://extensions or edge://extensions with Developer mode enabled.",
