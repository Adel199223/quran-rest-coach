  "contracts": {
    "template_read_policy": "docs/assistant/templates/* is read-only template material and should not be edited during app work.",
    "post_change_docs_sync_prompt_policy": "After significant implementation changes, ask exactly: Would you like me to run Assistant Docs Sync for this change now?",
    "sub_agent_routing_policy": "The main agent is the integrator; sub-agents are for narrow, bounded, mostly read-heavy exploration, disjoint validation, or tightly scoped docs work.",
    "validation_environment_policy": "Use WSL-safe wrappers for npm commands from this environment, treat http://127.0.0.1:4173 as the canonical standalone URL, and treat npm run build as the extension packaging validation command.",
