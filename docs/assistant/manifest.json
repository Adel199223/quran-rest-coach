    "validation_fallback_policy": "When live Quran.com automation is unavailable, use npm run build plus targeted tests and honest manual extension review instead of pretending a missing suite exists.",
    "user_guides_support_usage_policy": "Support and non-technical explanation tasks should start with the app user guides, then confirm against canonical technical docs if needed.",
    "user_guides_canonical_deference_policy": "User guides explain behavior plainly, but canonical technical docs and source code win when details conflict.",
    "user_guides_update_sync_policy": "Update only the user guides touched by the confirmed change; do not rewrite unrelated guides.",
    "golden_principles_source_of_truth": "docs/assistant/GOLDEN_PRINCIPLES.md",
    "execplan_policy": "Major or multi-file work should use docs/assistant/exec_plans/PLANS.md and create a plan in exec_plans/active/.",
    "approval_gates_policy": "AGENTS.md and agent.md define ask-before-execute triggers for destructive, risky, publish, history-rewrite, and non-essential network actions.",
    "worktree_isolation_policy": "This repo is git-backed now. Use worktrees or isolated branches for major parallel work, and prefer WSL-native git from this environment.",
    "local_persistence_source_of_truth": "docs/assistant/LOCAL_PERSISTENCE_KNOWLEDGE.md",
    "ui_surface_validation_policy": "docs/assistant/workflows/UI_SURFACE_VALIDATION_WORKFLOW.md is the source of truth for standalone browser validation, extension packaging checks, side-panel/chip smoke flow, locators, artifacts, and fallback behavior.",
    "benchmark_matrix_policy": "Create or refresh a benchmark matrix only for parity-sensitive UI work against named references.",
    "inspiration_reference_discovery_policy": "Run docs/assistant/workflows/REFERENCE_DISCOVERY_WORKFLOW.md before implementation decisions when the user requests parity or inspiration from a named product."
